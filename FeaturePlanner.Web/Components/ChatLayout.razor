@using FeaturePlanner.Web.Components.Layout

<div class="chat-layout-container h-screen flex flex-col">
    <!-- Sidebar Navigation -->
    <div class="sidebar hidden md:flex flex-col w-64 bg-slate-900 text-white overflow-hidden">
        <div class="p-4 border-b border-slate-700">
            <h1 class="text-xl font-bold">Feature Planner</h1>
        </div>
        
        <div class="flex-1 overflow-y-auto p-4">
            <nav class="space-y-2">
                <div class="text-xs font-semibold text-slate-400 uppercase mb-4">
                    Planning Sessions (Demo)
                </div>
                <div class="space-y-2">
                    @foreach (var session in DummySessions)
                    {
                        <button @onclick="() => HandleSessionClick(session)"
                                class="w-full text-left px-3 py-2 rounded hover:bg-slate-700 transition-colors text-sm text-slate-300 hover:text-white">
                            @session
                        </button>
                    }
                </div>
            </nav>
        </div>
    </div>

    <!-- Main Chat Area -->
    <div class="main-chat-area flex-1 flex flex-col bg-slate-50">
        <!-- Header -->
        <div class="border-b bg-white p-4 shadow-sm">
            <h2 class="text-lg font-semibold text-slate-900">Chat Interface</h2>
            <p class="text-sm text-slate-600 mt-1">Discuss your feature with the AI agent</p>
        </div>

        <!-- Chat Messages Area -->
        <div class="flex-1 overflow-y-auto p-6" @ref="MessagesContainerRef">
            <div class="max-w-3xl mx-auto space-y-4">
                @if (Messages.Count == 0)
                {
                    <div class="bg-white rounded-lg border border-slate-200 p-6 text-center text-slate-500">
                        <p>Start the interview by describing your feature or epic</p>
                    </div>
                }
                else
                {
                    @foreach (var message in Messages)
                    {
                        <div class="flex @(message.IsUserMessage ? "justify-end" : "justify-start")">
                            <div class="max-w-xl @(message.IsUserMessage ? "bg-blue-600 text-white" : "bg-white border border-slate-200") rounded-lg p-4">
                                <p class="text-sm">@message.Content</p>
                                <p class="text-xs @(message.IsUserMessage ? "text-blue-100" : "text-slate-400") mt-2">
                                    @message.Timestamp.ToString("HH:mm")
                                </p>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Input Area -->
        <div class="border-t bg-white p-4 shadow-sm">
            <div class="max-w-3xl mx-auto">
                <div class="flex gap-2">
                    <input type="text" 
                           @bind="InputValue"
                           @onkeyup="HandleKeyPress"
                           placeholder="Enter your feature description..." 
                           class="flex-1 px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                           disabled="@IsLoading" />
                    <button @onclick="HandleSend" 
                            class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 disabled:opacity-50"
                            disabled="@(IsLoading || string.IsNullOrWhiteSpace(InputValue))">
                        @(IsLoading ? "Loading..." : "Send")
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Toast Notification -->
<ToastNotification @ref="ToastRef" />

