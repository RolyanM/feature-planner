@if (IsVisible)
{
    <div class="toast-container fixed bottom-6 right-6 z-50">
        <div class="bg-blue-600 text-white px-6 py-4 rounded-lg shadow-lg flex gap-4 items-center">
            <span>@Message</span>
            <button @onclick="Hide" class="text-white hover:opacity-75">
                ✕
            </button>
        </div>
    </div>
}
